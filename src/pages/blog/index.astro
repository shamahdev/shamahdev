---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";

const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<Layout
  title="blog | shamah.dev"
  description="Writing about frontend engineering, products, and building."
>
  <Hero class="px-8 py-12 flex-col items-center">
    <Container>
      <main class="w-full flex flex-col gap-8">
        <div class="flex items-center justify-between gap-4">
          <h1 class="text-[32px] text-[#CECDC3] font-bold">blog</h1>
          <a href="/" class="text-sm text-[#CECDC3] underline">home</a>
        </div>

        {
          posts.length === 0 ? (
            <p class="text-[#6F6E6C]">No posts yet.</p>
          ) : (
            <ul class="flex flex-col gap-4">
              {posts.map((post) => (
                <li>
                  <a href={`/blog/${post.slug}`} class="block group">
                    <div class="flex flex-col gap-1">
                      <p class="text-[#CECDC3] font-semibold group-hover:underline">
                        {post.data.title}
                      </p>
                      <p class="text-sm text-[#6F6E6C]">
                        {post.data.description}
                      </p>
                      <p class="text-xs text-[#878580]">
                        {post.data.pubDate.toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "short",
                          day: "2-digit",
                        })}
                      </p>
                    </div>
                  </a>
                </li>
              ))}
            </ul>
          )
        }
      </main>
    </Container>
  </Hero>
</Layout>

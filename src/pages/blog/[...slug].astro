---
import { getCollection } from "astro:content";
import Container from "@/components/Container.astro";
import Hero from "@/components/Hero.astro";
import Layout from "@/layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog")).filter((p) => !p.data.draft);
  return posts.map((post) => ({ params: { slug: post.slug } }));
}

const { slug } = Astro.params;
const posts = await getCollection("blog");
const post = posts.find((p) => p.slug === slug);
if (!post || post.data.draft) return Astro.redirect("/blog");

const { Content } = await post.render();
---

<Layout
  title={`${post.data.title} | shamah.dev`}
  description={post.data.description}
>
  <Hero class="px-8 py-12 flex-col items-center">
    <Container>
      <main class="w-full flex flex-col gap-8">
        <div class="flex items-start justify-between gap-4">
          <div class="flex flex-col gap-2">
            <h1 class="text-[32px] text-[#CECDC3] font-bold">
              {post.data.title}
            </h1>
            <p class="text-sm text-[#6F6E6C]">{post.data.description}</p>
            <p class="text-xs text-[#878580]">
              {
                post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "short",
                  day: "2-digit",
                })
              }
            </p>
          </div>
          <a href="/blog" class="text-sm text-[#CECDC3] underline"
            >all posts</a
          >
        </div>

        <article class="prose prose-invert max-w-none">
          <Content />
        </article>
      </main>
    </Container>
  </Hero>
</Layout>

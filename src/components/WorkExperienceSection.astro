---
import { Picture } from "astro:assets";

import airmasImg from "@/assets/work-airmas.jpg";
import saltImg from "@/assets/work-salt.png";
import bddImg from "@/assets/work-bdd.png";
import kampusmerdekaImg from "@/assets/work-kampusmerdeka.png";
import studidevsecopsImg from "@/assets/work-studidevsecops.png";
import smeshubImg from "@/assets/work-smeshub.png";
import dicodingImg from "@/assets/work-dicoding.png";
import saltDashboardImg from "@/assets/salt/dashboard.png";
import saltAppImg from "@/assets/salt/app.png";
import smeshubWeb1Img from "@/assets/smeshub/web-1.png";
import smeshubWeb2Img from "@/assets/smeshub/web-2.png";
import smeshubWeb3Img from "@/assets/smeshub/web-3.png";
import dicodingCer1Img from "@/assets/dicoding/cer-1.png";
import dicodingCer2Img from "@/assets/dicoding/cer-2.png";
---

<div class="flex flex-col gap-4">
  <h2 class="text-lg font-semibold text-neutral-100">work experiences</h2>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 w-full">
    <div class="flex flex-col gap-4 w-full">
      <div
        class="bg-[#082243]/95 backdrop-blur rounded-xl py-6 px-8 flex flex-col justify-between w-full gap-8"
      >
        <div class="flex gap-4 items-center flex-wrap">
          <Picture
            src={airmasImg}
            alt="Airmas Group"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={60}
          />
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-neutral-100"><b>airmas group</b> / 2025 - present</h3>
          <p class="text-sm text-neutral-400 leading-loose">
            As a Frontend Engineer, I built and launched a new user interface
            for the AyooMall e-commerce platform using Next.js, significantly
            optimizing performance and business workflows.
          </p>
          <p class="text-sm text-neutral-400 leading-loose">
            I plan to take on more complex challenges, from mastering
            large-scale system architecture to driving cross-functional
            initiatives.
          </p>
        </div>
      </div>

      <div
        class="bg-black/15 backdrop-blur border border-neutral-900 rounded-xl py-6 px-8 flex flex-col justify-between w-full gap-8 relative overflow-hidden"
      >
        <div class="flex gap-4 items-center flex-wrap">
          <Picture
            src={saltImg}
            alt="Salt Indonesia"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={60}
          />
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-neutral-100"><b>salt</b> / 2023 - 2025</h3>
          <p class="text-sm text-neutral-400 leading-loose">
            Brought on board for SALT new branch in Bandung as a mid level
            front-end engineer.
          </p>
          <p class="text-sm text-neutral-400 leading-loose">
            Worked using React.js for coding and take care of code quality and
            deployment reliability by creating unit tests. Trusted by companies
            to work as an outsource in renowned companies like Telkomsel.
          </p>
        </div>
        <span class="h-70"></span>
        <div class="flex w-full gap-2 absolute -bottom-8 -right-16 items-end">
          <div class="relative motion-inview" data-from-y="50%">
            <div class="relative" style="width: 360px;">
              <Picture
                src={saltDashboardImg}
                alt="Salt Indonesia Dashboard"
                widths={[360, 720]}
                sizes="360px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
          <div class="relative motion-inview" data-from-y="80%">
            <div class="relative" style="width: 160px;">
              <Picture
                src={saltAppImg}
                alt="Salt Indonesia Mobile App"
                widths={[160, 320]}
                sizes="160px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-white/95 backdrop-blur rounded-xl py-6 px-8 flex flex-col justify-between w-full gap-8"
      >
        <div class="flex gap-4 items-center flex-wrap">
          <Picture
            src={bddImg}
            alt="BDD"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={60}
          />
          <Picture
            src={kampusmerdekaImg}
            alt="Kampus Merdeka x Dicoding"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={60}
          />
          <Picture
            src={studidevsecopsImg}
            alt="Studidevsecops"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={120}
          />
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-neutral-950">
            <b>speaking & mentoring</b> / 2022 - present
          </h3>
          <p class="text-sm text-neutral-800 leading-loose">
            I speak and facilitate workshop on several programs within frontend
            and project management expertise in collaboration with Dicoding.
          </p>
          <p class="text-sm text-neutral-800 leading-loose">
            Assist in creating a workshop syllabus for frontend development at
            Studidevsecops.
          </p>
        </div>
      </div>
    </div>

    <div class="flex flex-col w-full gap-4">
      <div
        class="from-white/95 via-white/95 to-[#FF621F]/95 bg-linear-to-b backdrop-blur rounded-xl py-6 px-8 flex flex-col justify-between w-full gap-8 relative overflow-hidden"
      >
        <div class="flex gap-4 items-center flex-wrap">
          <Picture
            src={smeshubImg}
            alt="Smeshub"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={120}
          />
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-neutral-950"><b>smeshub</b> / 2021 - 2023</h3>
          <p class="text-sm text-neutral-800 leading-loose">
            As the first engineering hired at Smeshub, I turned the founder's
            vision into a user-friendly MVP through full stack development.
          </p>
          <p class="text-sm text-neutral-800 leading-loose">
            Later, after our team grew, I assigned as a Frontend Engineer, I led
            a team and delivering high-quality front-end solutions.
          </p>
        </div>
        <span class="h-100"></span>
        <div
          class="flex w-full gap-2 absolute -bottom-16 left-0 right-0 items-end justify-center"
        >
          <div class="relative motion-inview" data-from-y="150px">
            <div class="relative" style="width: 300px;">
              <Picture
                src={smeshubWeb1Img}
                alt="Smeshub Platform - Profile Dashboard"
                widths={[300, 600]}
                sizes="300px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
          <div class="relative motion-inview" data-from-y="100px">
            <div class="relative" style="width: 300px;">
              <Picture
                src={smeshubWeb2Img}
                alt="Smeshub Platform - Landing Page"
                widths={[300, 600]}
                sizes="300px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
          <div class="relative motion-inview" data-from-y="150px">
            <div class="relative" style="width: 300px;">
              <Picture
                src={smeshubWeb3Img}
                alt="Smeshub Platform - Enterprise Page"
                widths={[300, 600]}
                sizes="300px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
        </div>
      </div>

      <div
        class="bg-[#15304E]/50 backdrop-blur rounded-xl py-6 px-8 flex flex-col justify-between w-full gap-8 relative overflow-hidden"
      >
        <div class="flex gap-4 items-center flex-wrap">
          <Picture
            src={dicodingImg}
            alt="Dicoding"
            loading="eager"
            decoding="async"
            style="object-fit: contain;"
            width={120}
          />
        </div>
        <div class="flex flex-col gap-3">
          <h3 class="text-neutral-100"><b>dicoding</b> / 2020 - present</h3>
          <p class="text-sm text-neutral-200 leading-loose">
            As an External Code Reviewer, I have successfully provided technical
            assistance and reviewed over 1200 project submissions from students.
          </p>
          <p class="text-sm text-neutral-200 leading-loose">
            I have helped many individuals graduate from Dicoding's courses,
            earning high ratings from satisfied students.
          </p>
        </div>
        <span class="h-60"></span>
        <div class="flex w-full gap-2 absolute bottom-0">
          <div class="relative motion-inview" data-from-y="50%">
            <div class="relative" style="width: 280px;">
              <Picture
                src={dicodingCer1Img}
                alt="Dicoding Academy Reviewer Certificate 2020"
                widths={[280, 560]}
                sizes="280px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
          <div class="relative motion-inview" data-from-y="80%">
            <div class="relative" style="width: 280px;">
              <Picture
                src={dicodingCer2Img}
                alt="Dicoding Academy Reviewer Certificate 2021"
                widths={[280, 560]}
                sizes="280px"
                loading="lazy"
                decoding="async"
                style="object-fit: cover;"
                layout="constrained"
              />
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { animate, inView } from "motion";

  document.querySelectorAll(".motion-inview").forEach((element) => {
    const el = element as HTMLElement;
    const fromY = el.dataset.fromY ?? "50%";
    el.style.transform = `translateY(${fromY})`;
    el.style.willChange = "transform";

    inView(el, () => {
      animate(
        el,
        { transform: "translateY(0)" },
        { duration: 0.5, ease: "backInOut" },
      );
    });
  });
</script>
